# Canonical host-side project manifest schema for remo broker v2 helpers.
schema_version = 1

[manifest]
required_fields = ["schema_version", "project"]
secret_table = "secrets"

[secrets]
fetch_as_default = "env"
file_modes = ["0600", "0640"]

[cache]
default_ttl_seconds = 900
default_max_entries = 50

[broker]
protocol_version = 2
admin_socket = "/run/remo-broker/admin.sock"
